# ─── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Database + queue ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chart_solar:chart_solar@localhost:5432/chart_solar
REDIS_URL=redis://localhost:6379/0

# ─── Frontend → API ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# CORS origins (JSON array). Default in code: ["http://localhost:3000"]
# CORS_ORIGINS=["http://localhost:3000"]

# ─── S3-compatible object storage (R2 / S3 / GCS / MinIO) ─────────────────────
# Leave blank to disable storage features.
S3_BUCKET=
S3_REGION=auto
# Set S3_ENDPOINT_URL for non-AWS providers (Cloudflare R2, MinIO). Leave blank for AWS S3.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Vertex AI (PDF extraction) ───────────────────────────────────────────────
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# Path to a JSON service-account file OR the JSON content itself.
VERTEX_CREDENTIALS_JSON=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Use test-mode keys (sk_test_…, pk_test_…) for non-production.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Resend (transactional email — magic links, audit delivery) ───────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@chartsolar.io

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=

# ─── Auth (FastAPI-native magic-link JWT path) ────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
AUTH_JWT_SECRET=
AUTH_MAGIC_LINK_TTL_SECONDS=900

# ─── NREL developer key (integration-tests harness only) ──────────────────────
# Used by tests/integration/oracles/pvwatts.py to fetch reference production
# data from PVWatts v8. Not read by the backend or frontend at runtime.
# Free to register at https://developer.nlr.gov/signup/
# (NREL migrated developer.nrel.gov → developer.nlr.gov; old host still 301-redirects.)
NREL_API_KEY=
